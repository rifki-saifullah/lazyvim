# Neovim AI Plugin API Keys
# Salin file ini ke .env dan isi dengan key Anda
# File .env TIDAK akan di-commit ke git

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama tidak memerlukan API key
# Pastikan server berjalan: ollama serve
